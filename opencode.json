{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "doom_loop": "allow",
    "external_directory": "deny",
    "webfetch": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      "secrets/*": "deny"
    },
    "edit": {
      "*": "allow",
      ".git/*": "deny"
    },
    "bash": {
      "*": "deny",
      "git *": "allow",
      "pytest *": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "limen *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "find *": "allow"
    }
  }
}
